# ── Supabase ───────────────────────────────────────────────────────────
# Project Settings > API no painel do Supabase
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-aqui

# ── URL pública ─────────────────────────────────────────────────────────
# Em produção: URL da Vercel  |  Em dev: http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── E-mail (opcional) ───────────────────────────────────────────────────
# Resend: https://resend.com (100 e-mails/dia grátis)
# Se não definida, as notificações por e-mail são silenciosamente ignoradas.
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM=AgendaPix <noreply@seudominio.com.br>

# ── WhatsApp API ────────────────────────────────────────────────────────
# Provedor: mock (padrão dev) | zapi | evolution | ultramsg
WHATSAPP_PROVIDER=mock

# Z-API  →  https://z-api.io
WHATSAPP_INSTANCE_ID=SUA_INSTANCIA
WHATSAPP_TOKEN=SEU_TOKEN
ZAPI_CLIENT_TOKEN=SEU_CLIENT_TOKEN

# Evolution API  →  instância self-hosted
# EVOLUTION_API_URL=https://seu-evolution.dominio.com.br
# WHATSAPP_INSTANCE_ID=nome-da-instancia
# WHATSAPP_TOKEN=global-api-key

# Ultramsg  →  https://ultramsg.com
# WHATSAPP_INSTANCE_ID=instanceXXXX
# WHATSAPP_TOKEN=seu-token
